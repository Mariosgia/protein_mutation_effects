# Figure
figure.figsize : 4.0, 3.0
figure.dpi : 150

# Fonts
font.size : 11
font.family : serif
font.weight : bold

# Axes
axes.labelsize : 18
axes.titlesize : 22
axes.labelweight : bold
axes.titleweight : bold
axes.linewidth : 1.0

# Ticks
xtick.labelsize : 11
ytick.labelsize : 11
xtick.direction : in
ytick.direction : in

# Grid
axes.grid : False

# Lines
lines.linewidth : 1.5

# Legend
legend.fontsize : 10
legend.frameon : False

# Save
savefig.bbox : tight